#!/usr/bin/env bash
# Build and package SolarExpanseLaunchWindows as a BepInEx zip.
# Output: dist/SolarExpanseLaunchWindows_v<version>.zip
set -euo pipefail

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(cd -- "$script_dir/.." && pwd)"
cd "$repo_root"

name="SolarExpanseLaunchWindows"
configuration="${CONFIGURATION:-Release}"
framework="net472"
dist_dir="dist"
staging_dir="$dist_dir/staging"

"$script_dir/build"

version="$(sed -nE 's/^## \[([0-9]+\.[0-9]+\.[0-9]+)\].*/\1/p' CHANGELOG.md | head -n 1)"
if [[ -z "$version" ]]; then
  echo "error: could not find a semantic version heading in CHANGELOG.md" >&2
  exit 1
fi

dll_path="src/mod/bin/$configuration/$framework/$name.dll"
if [[ ! -f "$dll_path" ]]; then
  echo "error: build output not found: $dll_path" >&2
  exit 1
fi

rm -rf "$staging_dir"
mkdir -p "$staging_dir/BepInEx/plugins"
cp "$dll_path" "$staging_dir/BepInEx/plugins/"

zip_path="$dist_dir/${name}_v${version}.zip"
mkdir -p "$dist_dir"
rm -f "$zip_path"
(
  cd "$staging_dir"
  zip -qr "../../${name}_v${version}.zip" BepInEx
)
rm -rf "$staging_dir"

echo "Packaged: $zip_path"
