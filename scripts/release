#!/usr/bin/env bash
# Package and create a GitHub release. Usage: scripts/release [version]
set -euo pipefail

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(cd -- "$script_dir/.." && pwd)"
cd "$repo_root"

name="SolarExpanseLaunchWindows"
version="${1:-}"

if ! command -v gh >/dev/null 2>&1; then
  echo "error: gh is required to create GitHub releases" >&2
  exit 1
fi

if [[ -z "$version" ]]; then
  raw_version="$(sed -nE 's/^## \[([0-9]+\.[0-9]+\.[0-9]+)\].*/\1/p' CHANGELOG.md | head -n 1)"
  if [[ -z "$raw_version" ]]; then
    echo "error: could not find a semantic version heading in CHANGELOG.md" >&2
    exit 1
  fi
  version="v$raw_version"
elif [[ "$version" != v* ]]; then
  version="v$version"
fi

numeric_version="${version#v}"
echo "Releasing $name $version..."

"$script_dir/package"

zip_path="dist/${name}_v${numeric_version}.zip"
if [[ ! -f "$zip_path" ]]; then
  echo "error: release archive not found: $zip_path" >&2
  exit 1
fi

notes="$(
  awk -v version="$numeric_version" '
    $0 ~ "^## \\[" version "\\]" { in_section = 1; next }
    in_section && $0 ~ "^## " { exit }
    in_section { print }
  ' CHANGELOG.md
)"

gh release create "$version" "$zip_path" --title "$name $version" --notes "$notes" --target main
echo "Done: https://github.com/stockmaj/solar-expanse-launch-windows/releases/tag/$version"
